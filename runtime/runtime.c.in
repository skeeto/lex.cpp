/* lex.cpp runtime helpers. Embedded into the generated scanner.
 *
 * The runtime is *always* organised around a yyguts_t struct. In
 * non-reentrant mode (the default), all state lives in a single
 * static instance and the public yytext/yyleng/etc. are real globals
 * that point at the struct. In reentrant mode (%option reentrant),
 * yyscan_t is a pointer to a heap-allocated yyguts_t; everything
 * goes through it, no globals. The macro YY_REENTRANT (defined by
 * codegen) selects between the two views.
 */

#define YY_BUF_SIZE 16384

/* YY_BUFFER_STATE typedef is forward-declared by codegen above. */
struct yy_buffer_state {
    FILE   *yy_input_file;
    char   *yyb_data;          /* renamed from yy_buf to avoid macro collision */
    size_t  yyb_size;          /* yy_buf_size  */
    size_t  yyb_pos;           /* yy_buf_pos   */
    size_t  yyb_end;           /* yy_buf_end   */
    int     yyb_at_bol;        /* yy_at_bol    */
    int     yyb_done;          /* yy_done      */
    int     yy_is_our_buffer;
    int     yy_is_interactive;
};

#ifndef YYLMAX
#define YYLMAX 8192
#endif

/* Defaults for bison interop. The bison-generated header normally
   provides YYSTYPE/YYLTYPE plus YYSTYPE_IS_DECLARED/YYLTYPE_IS_DECLARED
   before the runtime is included (PostgreSQL, GCC, ...); the fallbacks
   let non-bison-bridge scanners still compile cleanly. Probe both the
   `*_IS_DECLARED` flag (bison convention) and the macro itself (some
   .l files spell it `#define YYLTYPE int` -- PostgreSQL does). */
#if !defined(YYSTYPE) && !defined(YYSTYPE_IS_DECLARED)
typedef int YYSTYPE;
#define YYSTYPE_IS_DECLARED 1
#endif
#if !defined(YYLTYPE) && !defined(YYLTYPE_IS_DECLARED)
typedef int YYLTYPE;
#define YYLTYPE_IS_DECLARED 1
#endif

struct yyguts_t {
    YY_BUFFER_STATE *yy_buffer_stack_r;
    size_t           yy_buffer_stack_max_r;
    size_t           yy_buffer_stack_top_r;
    int             *yy_state_stack_r;
    size_t           yy_state_stack_max_r;
    size_t           yy_state_stack_top_r;
#if YY_ARRAY
    char             yytext_r[YYLMAX];
#else
    char            *yytext_r;
#endif
    int              yyleng_r;
    int              yylineno_r;
    FILE            *yyin_r;
    FILE            *yyout_r;
    int              yy_start_r;
    char             yy_text_save_r;
    int              yy_text_active_r;
    int              yy_init_done_r;
    int              yy_more_flag_r;
    int              yy_more_offset_r;
    YY_EXTRA_TYPE    yyextra_r;    /* user-provided type via %option extra-type */
    /* bison-bridge / bison-locations: typed so that *yylval / *yylloc
       work as proper lvalues at the call site (PostgreSQL's scan.l
       relies on this). The user's bison-generated header provides
       YYSTYPE/YYLTYPE before the runtime is included. */
    YYSTYPE         *yylval_r;
    YYLTYPE         *yylloc_r;
};
typedef struct yyguts_t yyguts_t;

#if YY_REENTRANT
/* yyscan_t is typedef'd by codegen forward decl. */
#define YY_G          ((yyguts_t*)yyscanner)
#define YY_DECLPM     yyscan_t yyscanner
#define YY_DECLPM_C   , yyscan_t yyscanner
#define YY_CALLPM     yyscanner
#define YY_CALLPM_C   , yyscanner
/* Place at the top of every reentrant helper that touches the
   yytext/yyleng/yylineno/yyin/yyout/yyextra macros (they expand to
   yyg->...). The (void)yyg cast suppresses unused warnings in
   functions that only use the macros indirectly. */
#define YY_PRELUDE    struct yyguts_t *yyg = (struct yyguts_t *)yyscanner; \
                      (void)yyg;

/* In reentrant mode, the public yy* names resolve through the
   parameter. They are macros, so an `extern char *yytext;` in user
   code is a compile error -- as it should be. */
/* Reentrant accessors. flex's convention is that the caller declares
   `struct yyguts_t *yyg = (struct yyguts_t *)scanner;` and these
   macros expand to `yyg->...`. Codegen does this declaration at the
   top of the yylex() body. User code that calls yytext/yyleng/etc.
   from outside yylex (e.g. PostgreSQL's guc-file flow) must declare
   its own yyg pointer the same way. */
#define yytext         (yyg->yytext_r)
#define yyleng         (yyg->yyleng_r)
#define yylineno       (yyg->yylineno_r)
#define yyin           (yyg->yyin_r)
#define yyout          (yyg->yyout_r)
#define yyextra        (yyg->yyextra_r)

#else
/* Non-reentrant: real globals. */
static yyguts_t yy_global_guts_;
#define YY_G          (&yy_global_guts_)
#define YY_DECLPM     void
#define YY_DECLPM_C
#define YY_CALLPM
#define YY_CALLPM_C
#define YY_PRELUDE    /* nothing in non-reentrant mode */

#if YY_ARRAY
char  yytext[YYLMAX];
#else
char *yytext   = 0;
#endif
int   yyleng   = 0;
int   yylineno = 1;
FILE *yyin     = 0;
FILE *yyout    = 0;

/* Within helper bodies the yy* names need to refer to the same storage
   as the public globals. In non-reentrant mode YY_G->yytext_r is
   unused; we keep the public globals authoritative and the helpers
   read/write them directly. The yyguts_t struct in this mode only
   carries members that have no public alias (yy_start, yy_text_save,
   etc.). The names below are the public globals. */
#endif

/* Internal state names. These resolve to YY_G->...; same in both modes. */
#define yy_start              (YY_G->yy_start_r)
#define yy_text_save          (YY_G->yy_text_save_r)
#define yy_text_active        (YY_G->yy_text_active_r)
#define yy_buffer_stack       (YY_G->yy_buffer_stack_r)
#define yy_buffer_stack_max   (YY_G->yy_buffer_stack_max_r)
#define yy_buffer_stack_top   (YY_G->yy_buffer_stack_top_r)
#define yy_state_stack       (YY_G->yy_state_stack_r)
#define yy_state_stack_max   (YY_G->yy_state_stack_max_r)
#define yy_state_stack_top   (YY_G->yy_state_stack_top_r)
#define yy_init_done          (YY_G->yy_init_done_r)
#define yy_more_flag          (YY_G->yy_more_flag_r)
#define yy_more_offset        (YY_G->yy_more_offset_r)

#define YY_CURRENT_BUFFER \
    (yy_buffer_stack ? yy_buffer_stack[yy_buffer_stack_top] : (YY_BUFFER_STATE)0)
#define YY_CURRENT_BUFFER_LVALUE  yy_buffer_stack[yy_buffer_stack_top]

#if !YY_REENTRANT
extern int yywrap(void);
#endif

/* yy_size_t is a flex compatibility alias for size_t; some user .l
   files reference it directly (PostgreSQL, ecpg). */
typedef size_t yy_size_t;

/* User-overridable allocator hooks. flex routes ALL allocation through
   yyalloc/yyrealloc/yyfree so applications can substitute palloc-like
   backends. The default is plain malloc/realloc/free. Suppressed via
   `%option noyyalloc` etc. when the user provides their own. */
#ifndef YY_NO_YYALLOC
static void *yyalloc(yy_size_t n YY_DECLPM_C) {
    return malloc(n);
}
#endif
#ifndef YY_NO_YYREALLOC
static void *yyrealloc(void *p, yy_size_t n YY_DECLPM_C) {
    return realloc(p, n);
}
#endif
#ifndef YY_NO_YYFREE
static void yyfree(void *p YY_DECLPM_C) {
    free(p);
}
#endif

/* Fatal-error reporting. Routed through a single helper so that user
   code that overrides fprintf via macros (e.g. PostgreSQL's
   `#define fprintf(file, fmt, msg) fprintf_to_ereport(fmt, msg)`)
   doesn't trip on our internal calls. Override either YY_FATAL_ERROR
   or yy_fatal_error to redirect. */
static void yy_fatal_error(const char *msg YY_DECLPM_C) {
    fputs(msg, stderr);
    fputc('\n', stderr);
    exit(2);
}
#ifndef YY_FATAL_ERROR
#define YY_FATAL_ERROR(msg) yy_fatal_error(msg YY_CALLPM_C)
#endif

/* GCC's own bootstrap poisons calloc/strdup/strndup via
 *   #pragma GCC poison calloc strdup strndup
 * in gcc/system.h. We avoid calloc entirely; users embedding the
 * generated scanner in environments with similar bans see no calls. */
static void *yy_zalloc(size_t n) {
    void *p = malloc(n);
    if (p) memset(p, 0, n);
    return p;
}

/* ---- buffer-stack management --------------------------------------- */

static void yyensure_buffer_stack(YY_DECLPM) { YY_PRELUDE
    if (!yy_buffer_stack) {
        yy_buffer_stack_max = 1;
        yy_buffer_stack = (YY_BUFFER_STATE*)
            yy_zalloc(yy_buffer_stack_max * sizeof(YY_BUFFER_STATE));
        if (!yy_buffer_stack) {
            YY_FATAL_ERROR("lex: out of memory");
        }
        yy_buffer_stack_top = 0;
    }
}

static void yy_grow_stack(YY_DECLPM) { YY_PRELUDE
    size_t new_max = yy_buffer_stack_max ? yy_buffer_stack_max * 2 : 4;
    YY_BUFFER_STATE *p = (YY_BUFFER_STATE*)
        realloc(yy_buffer_stack, new_max * sizeof(YY_BUFFER_STATE));
    if (!p) { YY_FATAL_ERROR("lex: out of memory"); }
    for (size_t i = yy_buffer_stack_max; i < new_max; ++i) p[i] = 0;
    yy_buffer_stack = p;
    yy_buffer_stack_max = new_max;
}

YY_BUFFER_STATE yy_create_buffer(FILE *file, int size YY_DECLPM_C) { YY_PRELUDE
    YY_BUFFER_STATE b = (YY_BUFFER_STATE)yy_zalloc(sizeof(*b));
    if (!b) return 0;
    b->yyb_size = (size > 0) ? (size_t)size : YY_BUF_SIZE;
    b->yyb_data = (char*)malloc(b->yyb_size + 2);
    if (!b->yyb_data) { free(b); return 0; }
    b->yyb_data[0] = 0;
    b->yyb_data[1] = 0;
    b->yy_input_file     = file;
    b->yyb_at_bol         = 1;
    b->yyb_done           = 0;
    b->yyb_pos        = 0;
    b->yyb_end        = 0;
    b->yy_is_our_buffer  = 1;
    return b;
}

void yy_delete_buffer(YY_BUFFER_STATE b YY_DECLPM_C) { YY_PRELUDE
    if (!b) return;
    if (b->yy_is_our_buffer) free(b->yyb_data);
    free(b);
}

void yy_flush_buffer(YY_BUFFER_STATE b YY_DECLPM_C) { YY_PRELUDE
    if (!b) return;
    b->yyb_pos = 0;
    b->yyb_end = 0;
    b->yyb_done    = (b->yy_input_file == 0) ? 1 : 0;
    b->yyb_at_bol  = 1;
    if (b->yyb_data) {
        b->yyb_data[0] = 0;
        b->yyb_data[1] = 0;
    }
}

void yy_switch_to_buffer(YY_BUFFER_STATE b YY_DECLPM_C) { YY_PRELUDE
    yyensure_buffer_stack(YY_CALLPM);
    if (YY_CURRENT_BUFFER == b) return;
    YY_CURRENT_BUFFER_LVALUE = b;
    if (b) yyin = b->yy_input_file;
}

void yypush_buffer_state(YY_BUFFER_STATE b YY_DECLPM_C) { YY_PRELUDE
    yyensure_buffer_stack(YY_CALLPM);
    if (YY_CURRENT_BUFFER) {
        ++yy_buffer_stack_top;
        if (yy_buffer_stack_top >= yy_buffer_stack_max) yy_grow_stack(YY_CALLPM);
    }
    YY_CURRENT_BUFFER_LVALUE = b;
    if (b) yyin = b->yy_input_file;
}

void yypop_buffer_state(YY_DECLPM) { YY_PRELUDE
    if (!yy_buffer_stack) return;
    yy_delete_buffer(YY_CURRENT_BUFFER YY_CALLPM_C);
    YY_CURRENT_BUFFER_LVALUE = 0;
    if (yy_buffer_stack_top > 0) {
        --yy_buffer_stack_top;
        if (YY_CURRENT_BUFFER) yyin = YY_CURRENT_BUFFER->yy_input_file;
    }
}

/* ---- scan-from-memory entry points --------------------------------- */

YY_BUFFER_STATE yy_scan_buffer(char *base, size_t size YY_DECLPM_C) { YY_PRELUDE
    if (size < 2 || base[size - 2] != 0 || base[size - 1] != 0) return 0;
    YY_BUFFER_STATE b = (YY_BUFFER_STATE)yy_zalloc(sizeof(*b));
    if (!b) return 0;
    b->yyb_data            = base;
    b->yyb_size       = size - 2;
    b->yyb_end        = size - 2;
    b->yyb_pos        = 0;
    b->yyb_at_bol         = 1;
    b->yyb_done           = 1;
    b->yy_is_our_buffer  = 0;
    yypush_buffer_state(b YY_CALLPM_C);
    return b;
}

YY_BUFFER_STATE yy_scan_bytes(const char *bytes, int len YY_DECLPM_C) { YY_PRELUDE
    if (len < 0) len = 0;
    size_t n = (size_t)len;
    char *buf = (char*)malloc(n + 2);
    if (!buf) return 0;
    if (n) memcpy(buf, bytes, n);
    buf[n] = 0;
    buf[n + 1] = 0;
    YY_BUFFER_STATE b = (YY_BUFFER_STATE)yy_zalloc(sizeof(*b));
    if (!b) { free(buf); return 0; }
    b->yyb_data            = buf;
    b->yyb_size       = n;
    b->yyb_end        = n;
    b->yyb_pos        = 0;
    b->yyb_at_bol         = 1;
    b->yyb_done           = 1;
    b->yy_is_our_buffer  = 1;
    yypush_buffer_state(b YY_CALLPM_C);
    return b;
}

YY_BUFFER_STATE yy_scan_string(const char *s YY_DECLPM_C) { YY_PRELUDE
    return yy_scan_bytes(s, s ? (int)strlen(s) : 0 YY_CALLPM_C);
}

/* ---- buffer-aware low-level helpers -------------------------------- */

static void yy_buf_grow(YY_BUFFER_STATE b, size_t want YY_DECLPM_C) { YY_PRELUDE
    if (b->yyb_size >= want) return;
    size_t s = b->yyb_size ? b->yyb_size : 4096;
    while (s < want) s *= 2;
    char *p = (char*)realloc(b->yyb_data, s + 2);
    if (!p) { YY_FATAL_ERROR("lex: out of memory"); }
    b->yyb_data = p;
    b->yyb_size = s;
    b->yyb_data[b->yyb_end]     = 0;
    b->yyb_data[b->yyb_end + 1] = 0;
}

/* User-overridable input hook. The default reads from yyin via fread. */
#ifndef YY_INPUT
#define YY_INPUT(buf, result, max_size)                                    \
    ((result) = fread((buf), 1, (max_size), yyin))
#endif

static void yy_refill(YY_DECLPM) { YY_PRELUDE
    YY_BUFFER_STATE b = YY_CURRENT_BUFFER;
    if (!b || b->yyb_done) return;
    yy_buf_grow(b, b->yyb_end + 4096 YY_CALLPM_C);
    size_t n = 0;
    {
        char *yy_input_buf = b->yyb_data + b->yyb_end;
        size_t yy_input_max = b->yyb_size - b->yyb_end;
        YY_INPUT(yy_input_buf, n, yy_input_max);
    }
    b->yyb_end += n;
    if (n == 0) b->yyb_done = 1;
    b->yyb_data[b->yyb_end]     = 0;
    b->yyb_data[b->yyb_end + 1] = 0;
}

static void yy_slurp(YY_DECLPM) { YY_PRELUDE
    YY_BUFFER_STATE b = YY_CURRENT_BUFFER;
    if (!b) return;
    while (!b->yyb_done) yy_refill(YY_CALLPM);
}

static void yy_init_default_buffer(YY_DECLPM) { YY_PRELUDE
    yyensure_buffer_stack(YY_CALLPM);
    if (!YY_CURRENT_BUFFER) {
        if (!yyin) yyin = stdin;
        YY_CURRENT_BUFFER_LVALUE = yy_create_buffer(yyin, YY_BUF_SIZE YY_CALLPM_C);
        yy_slurp(YY_CALLPM);
    }
    yy_init_done = 1;
}

void yyrestart(FILE *new_input YY_DECLPM_C) { YY_PRELUDE
    yyensure_buffer_stack(YY_CALLPM);
    if (!YY_CURRENT_BUFFER) {
        YY_CURRENT_BUFFER_LVALUE = yy_create_buffer(new_input, YY_BUF_SIZE YY_CALLPM_C);
    } else {
        YY_CURRENT_BUFFER->yy_input_file = new_input;
        yy_flush_buffer(YY_CURRENT_BUFFER YY_CALLPM_C);
    }
    yyin = new_input;
    yy_text_active = 0;
    yy_text_save = 0;
    /* yy_start is intentionally preserved; flex's yyrestart leaves
       it alone so user-set start conditions survive across file
       transitions. */
#if YY_ARRAY
    yytext[0] = 0;
#else
    yytext = 0;
#endif
    yyleng = 0;
    yy_slurp(YY_CALLPM);
}

/* ---- yytext sealing ------------------------------------------------ */

static void yy_text_seal(YY_DECLPM) { YY_PRELUDE
    if (yy_text_active && yytext) {
        yy_text_save = yytext[yyleng];
        yytext[yyleng] = 0;
    }
}
static void yy_text_unseal(YY_DECLPM) { YY_PRELUDE
    if (yy_text_active && yytext) {
        yytext[yyleng] = yy_text_save;
        yy_text_active = 0;
    }
}

/* ---- unput / input / yyless --------------------------------------- */

static void yy_unput(int c YY_DECLPM_C) { YY_PRELUDE
    yy_text_unseal(YY_CALLPM);
    YY_BUFFER_STATE b = YY_CURRENT_BUFFER;
    if (!b) return;
    if (b->yyb_pos == 0) {
        yy_buf_grow(b, b->yyb_end + 1 YY_CALLPM_C);
        memmove(b->yyb_data + 1, b->yyb_data, b->yyb_end);
        b->yyb_end += 1;
        b->yyb_pos = 1;
    }
    b->yyb_data[--b->yyb_pos] = (char)c;
    b->yyb_at_bol = (c == '\n') ? 1 : 0;
}

static int yy_input(YY_DECLPM) { YY_PRELUDE
    yy_text_unseal(YY_CALLPM);
    YY_BUFFER_STATE b = YY_CURRENT_BUFFER;
    if (!b) return 0;
    if (b->yyb_pos >= b->yyb_end) yy_refill(YY_CALLPM);
    if (b->yyb_pos >= b->yyb_end) return 0;
    unsigned char c = (unsigned char)b->yyb_data[b->yyb_pos++];
    if (YY_TRACK_LINENO && c == '\n') yylineno++;
    return (int)c;
}

static void yy_do_yyless(int n YY_DECLPM_C) { YY_PRELUDE
    YY_BUFFER_STATE b = YY_CURRENT_BUFFER;
    yytext[yyleng] = yy_text_save;
    b->yyb_pos -= (size_t)(yyleng - n);
    yyleng = n;
    yy_text_save = yytext[yyleng];
    yytext[yyleng] = 0;
    b->yyb_at_bol = (n > 0 && yytext[n - 1] == '\n');
}

/* ---- start-condition stack ---------------------------------------- */

static void yy_grow_state_stack(YY_DECLPM) { YY_PRELUDE
    size_t new_max = yy_state_stack_max ? yy_state_stack_max * 2 : 16;
    int *p = (int*)realloc(yy_state_stack, new_max * sizeof(int));
    if (!p) { YY_FATAL_ERROR("lex: out of memory"); }
    yy_state_stack = p;
    yy_state_stack_max = new_max;
}

void yy_push_state(int new_state YY_DECLPM_C) {
    if (yy_state_stack_top >= yy_state_stack_max)
        yy_grow_state_stack(YY_CALLPM);
    yy_state_stack[yy_state_stack_top++] = yy_start;
    yy_start = new_state;
}

void yy_pop_state(YY_DECLPM) { YY_PRELUDE
    if (yy_state_stack_top == 0) return;
    yy_start = yy_state_stack[--yy_state_stack_top];
}

int yy_top_state(YY_DECLPM) { YY_PRELUDE
    if (yy_state_stack_top == 0) {
        YY_FATAL_ERROR("yy_top_state(): empty stack");
    }
    return yy_state_stack[yy_state_stack_top - 1];
}

/* Diagnostic emitted on jam (no rule matched, %option nodefault).
   Reports the offending byte (printable form when possible), buffer
   offset, current start condition, and the line number when
   yylineno tracking is enabled. Routed through YY_FATAL_ERROR so a
   user override (e.g. PostgreSQL's ereport-based handler) gets the
   message instead of stderr. */
static void yy_jam_report(YY_DECLPM) { YY_PRELUDE
    YY_BUFFER_STATE b = YY_CURRENT_BUFFER;
    unsigned char ch = (b && b->yyb_pos < b->yyb_end)
        ? (unsigned char)b->yyb_data[b->yyb_pos] : 0;
    size_t off = b ? b->yyb_pos : 0;
    char buf[160];
    if (ch >= 0x20 && ch < 0x7f && ch != '\\' && ch != '\'') {
        snprintf(buf, sizeof buf,
                 "scanner jammed at byte 0x%02x ('%c'), "
                 "offset %zu, line %d, start-condition %d",
                 ch, ch, off, yylineno, yy_start);
    } else {
        snprintf(buf, sizeof buf,
                 "scanner jammed at byte 0x%02x, "
                 "offset %zu, line %d, start-condition %d",
                 ch, off, yylineno, yy_start);
    }
    YY_FATAL_ERROR(buf);
}

/* The codegen-emitted yylex body refers to these as bare names; expose
   them as macros that route through YY_CURRENT_BUFFER's renamed fields. */
#define yy_buf       (YY_CURRENT_BUFFER->yyb_data)
#define yy_buf_size  (YY_CURRENT_BUFFER->yyb_size)
#define yy_buf_pos   (YY_CURRENT_BUFFER->yyb_pos)
#define yy_buf_end   (YY_CURRENT_BUFFER->yyb_end)
#define yy_at_bol    (YY_CURRENT_BUFFER->yyb_at_bol)
#define yy_done      (YY_CURRENT_BUFFER->yyb_done)

#define yymore()        ((void)(yy_more_flag = 1))
#define yy_set_bol(at)  ((void)(yy_at_bol = (at) ? 1 : 0))
#define YY_AT_BOL()     (yy_at_bol)
/* flex permits both `BEGIN(X)` and `BEGIN X;` -- expressed via a
   trick where BEGIN expands to a partial assignment. We mimic that. */
#define BEGIN           yy_start =
#define YY_START        (yy_start)
/* flex synonym for YY_START. */
#define YYSTATE         YY_START
/* flex's sentinel byte at the end of the input buffer. We don't use it
   internally (our buffer is positionally bounded), but user .l files
   sometimes test against it directly (PostgreSQL's scan.l does). */
#ifndef YY_END_OF_BUFFER_CHAR
#define YY_END_OF_BUFFER_CHAR 0
#endif
#define ECHO            (void)fwrite(yytext, 1, (size_t)yyleng, yyout)
/* yyterminate() returns 0; yyterminate(VAL) returns VAL.
 * Uses __VA_OPT__ -- standard in C2x, accepted by gcc/clang as a
 * C99/C11 extension, and by MSVC with /Zc:preprocessor.
 * User .l files are free to define their own yyterminate first. */
#ifndef yyterminate
#define yyterminate(...) return (0 __VA_OPT__(,) __VA_ARGS__)
#endif
#define unput(c)        yy_unput((int)(unsigned char)(c) YY_CALLPM_C)
#define input()         yy_input(YY_CALLPM)
#define yyless(n)       yy_do_yyless((int)(n) YY_CALLPM_C)

/* ---- reentrant init/destroy + accessors --------------------------- */
#if YY_REENTRANT
int yylex_init(yyscan_t *scanner) {
    if (!scanner) return 1;
    yyguts_t *g = (yyguts_t*)yy_zalloc(sizeof(yyguts_t));
    if (!g) { *scanner = 0; return 1; }
    /* yylineno_r left at 0 -- flex's reentrant convention. */
    *scanner = g;
    return 0;
}

int yylex_init_extra(YY_EXTRA_TYPE user_extra, yyscan_t *scanner) {
    int rc = yylex_init(scanner);
    if (rc) return rc;
    ((yyguts_t*)*scanner)->yyextra_r = user_extra;
    return 0;
}

int yylex_destroy(yyscan_t scanner) {
    if (!scanner) return 0;
    yyguts_t *g = (yyguts_t*)scanner;
    /* free all buffers on the stack */
    while (g->yy_buffer_stack_r) {
        YY_BUFFER_STATE b = g->yy_buffer_stack_r[g->yy_buffer_stack_top_r];
        if (b) {
            if (b->yy_is_our_buffer) free(b->yyb_data);
            free(b);
            g->yy_buffer_stack_r[g->yy_buffer_stack_top_r] = 0;
        }
        if (g->yy_buffer_stack_top_r == 0) break;
        --g->yy_buffer_stack_top_r;
    }
    free(g->yy_buffer_stack_r);
    free(g->yy_state_stack_r);
    free(g);
    return 0;
}

char *yyget_text(yyscan_t s) { return ((yyguts_t*)s)->yytext_r; }
int   yyget_leng(yyscan_t s) { return ((yyguts_t*)s)->yyleng_r; }
int   yyget_lineno(yyscan_t s) { return ((yyguts_t*)s)->yylineno_r; }
void  yyset_lineno(int v, yyscan_t s) { ((yyguts_t*)s)->yylineno_r = v; }
FILE *yyget_in(yyscan_t s)  { return ((yyguts_t*)s)->yyin_r; }
void  yyset_in(FILE *f, yyscan_t s) { ((yyguts_t*)s)->yyin_r = f; }
FILE *yyget_out(yyscan_t s) { return ((yyguts_t*)s)->yyout_r; }
void  yyset_out(FILE *f, yyscan_t s){ ((yyguts_t*)s)->yyout_r = f; }
YY_EXTRA_TYPE yyget_extra(yyscan_t s){ return ((yyguts_t*)s)->yyextra_r; }
void  yyset_extra(YY_EXTRA_TYPE v, yyscan_t s){ ((yyguts_t*)s)->yyextra_r = v; }
int   yyget_debug(yyscan_t s){ (void)s; return 0; }
void  yyset_debug(int v, yyscan_t s){ (void)v; (void)s; }

/* `_r`-suffixed aliases. lex.cpp extension; some downstream code
   (older bison-bridge bindings) looks the accessors up by these
   names. Forwarders, no behavioural difference. */
static inline char *yyget_text_r(yyscan_t s) { return yyget_text(s); }
static inline int   yyget_leng_r(yyscan_t s) { return yyget_leng(s); }
static inline int   yyget_lineno_r(yyscan_t s) { return yyget_lineno(s); }
static inline void  yyset_lineno_r(int v, yyscan_t s) { yyset_lineno(v, s); }
static inline FILE *yyget_in_r(yyscan_t s) { return yyget_in(s); }
static inline void  yyset_in_r(FILE *f, yyscan_t s) { yyset_in(f, s); }
static inline FILE *yyget_out_r(yyscan_t s) { return yyget_out(s); }
static inline void  yyset_out_r(FILE *f, yyscan_t s) { yyset_out(f, s); }
static inline YY_EXTRA_TYPE yyget_extra_r(yyscan_t s) { return yyget_extra(s); }
static inline void  yyset_extra_r(YY_EXTRA_TYPE v, yyscan_t s) { yyset_extra(v, s); }
#endif
